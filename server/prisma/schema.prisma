datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Admin {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  username     String        @unique
  email        String        @unique
  passwordHash String
  role         String        @default("ADMIN") // SUPER_ADMIN or ADMIN
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  ActivityLog  ActivityLog[]
}

model Kalpana {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  description   String?
  documentUrl   String?
  displayOrder  Int      @default(0)
  isVisible     Boolean  @default(true)
  publishedDate DateTime
  createdAt     DateTime @default(now())
}

model TeamMember {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  designation  String
  category     String   // CORE_LEADER, DISTRICT_PRESIDENT, DISTRICT_SECRETARY
  district     String?
  contactEmail String?
  contactPhone String?
  imageUrl     String?
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
}

model Event {
  id            String         @id @map("_id") // Unique slug, e.g. "silentium-2k25"
  title         String
  description   String?
  eventDate     DateTime
  location      String?
  featuredImage String?
  isPublished   Boolean        @default(false)
  createdAt     DateTime       @default(now())
  galleryMedia  GalleryMedia[]
}

model GalleryMedia {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId      String
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  type         String   // IMAGE or VIDEO
  mediaUrl     String
  title        String?
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
}

model Article {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  slug          String   @unique
  content       String
  featuredImage String?
  authorName    String
  category      String?
  status        String   @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  publishDate   DateTime @default(now())
  createdAt     DateTime @default(now())
}

model ActivityLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  adminId     String?  @db.ObjectId
  admin       Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)
  action      String   // CREATE, UPDATE, DELETE, LOGIN
  module      String   // Kalpanas, TeamMembers, Events, Gallery, Articles, Admins
  description String
  ipAddress   String?
  timestamp   DateTime @default(now())
}
